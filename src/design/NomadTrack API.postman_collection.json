        {
          "name": "Login (sets {{jwt}})",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "try {",
                  "  const data = pm.response.json();",
                  "  if (data.accessToken) {",
                  "    pm.collectionVariables.set('jwt', data.accessToken);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
